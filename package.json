{
  "name": "premium-travel-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "start:prod": "prisma migrate deploy && node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "latest",
    "@fastify/helmet": "latest",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "latest",
    "@prisma/client": "^6.19.3",
    "dotenv": "latest",
    "fastify": "latest",
    "prisma": "^6.19.3",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "pino-pretty": "^13.1.3",
    "tsc-alias": "^1.8.17",
    "tsx": "latest",
    "typescript": "latest"
  }
}
