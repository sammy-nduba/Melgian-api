NODE_ENV="production"
PORT=10000

# PostgreSQL connection string (use your cloud DB URL on Render)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

FRONTEND_URL="https://your-frontend-url.com"

ADMIN_API_SECRET="change-this-secret"

JWT_SECRET="generate-a-secure-secret-key"

BOOKING_NOTIFICATION_EMAIL="bookings@yourdomain.com"
